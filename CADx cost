#### RUN_OD_CADX_OVERLAY_FIXED.R
#### One-go runner: sources CEA_030326.R then computes OD overlays (RAD_NORMAL, DISCARD_LITE, LIS)
#### by provider (ENDO vs CADX) and country; includes main and extended costs; safe Excel export.
#### Adds a simple output table with:
#### - CADe-only cost per CRC prevented
#### - CADe + CADx cost per CRC prevented
#### - Incremental CADx cost per CRC prevented (CADe+CADx minus CADe-only)

suppressPackageStartupMessages({
  library(dplyr)
  library(purrr)
  library(tidyr)
  library(tibble)
  library(writexl)
  library(scales)
})

options(dplyr.summarise.inform = FALSE)

# -----------------------------
# 0) SAFE XLSX WRITER
# -----------------------------
safe_write_xlsx <- function(sheets, path) {
  dir.create(dirname(path), recursive = TRUE, showWarnings = FALSE)
  tryCatch({
    writexl::write_xlsx(sheets, path)
    message("Wrote: ", normalizePath(path, winslash = "/", mustWork = FALSE))
  }, error = function(e) {
    alt <- sub("\\.xlsx$", paste0("_", format(Sys.time(), "%Y%m%d_%H%M%S"), ".xlsx"), path)
    message("Primary write failed: ", conditionMessage(e))
    message("Trying: ", normalizePath(alt, winslash = "/", mustWork = FALSE))
    writexl::write_xlsx(sheets, alt)
    message("Wrote: ", normalizePath(alt, winslash = "/", mustWork = FALSE))
  })
}

# -----------------------------
# 1) HELPERS
# -----------------------------
safe_divide <- function(num, den) {
  ifelse(is.na(den) | den == 0, NA_real_, num / den)
}

pv_factor <- function(years, discount) {
  sum(1 / (1 + discount)^(seq_len(years)))
}

pick_col <- function(df, candidates) {
  hit <- intersect(candidates, names(df))
  if (length(hit) == 0) NA_character_ else hit[[1]]
}

norm_country <- function(x) {
  x <- toupper(trimws(as.character(x)))
  x <- gsub("[^A-Z]", "", x)
  dplyr::case_when(
    x %in% c("US", "USA", "UNITEDSTATES") ~ "US",
    x %in% c("UK", "UNITEDKINGDOM", "GB", "GREATBRITAIN", "ENGLAND") ~ "UK",
    x %in% c("JAPAN", "JP") ~ "JAPAN",
    x %in% c("NORWAY", "NO") ~ "NORWAY",
    TRUE ~ x
  )
}

norm_provider <- function(x) {
  x <- toupper(trimws(as.character(x)))
  x <- gsub("[^A-Z]", "", x)
  dplyr::case_when(
    x %in% c("ENDO", "ENDOSCOPIST", "ENDOSCOPISTALONE", "PHYSICIAN") ~ "ENDO",
    x %in% c("CADX", "CAD", "AI", "AID", "CADXASSISTED") ~ "CADX",
    TRUE ~ x
  )
}

norm_strategy <- function(x) {
  x <- toupper(trimws(as.character(x)))
  x <- gsub("[^A-Z_]", "", x)
  dplyr::case_when(
    x %in% c("RAD", "RADNORMAL", "RAD_NORMAL") ~ "RAD_NORMAL",
    x %in% c("DISCARD", "DISCARDLITE", "DISCARD_LITE") ~ "DISCARD_LITE",
    x %in% c("LIS", "LEAVEINSITU", "LEAVE_IN_SITU") ~ "LIS",
    x %in% c("TOTALREMOVAL", "TOTAL_REMOVAL", "REFERENCE", "REF") ~ "TOTAL_REMOVAL",
    TRUE ~ x
  )
}

# surveillance mapping:
# shorter interval => +1 follow-up within 10 years
# longer interval  => -1 follow-up within 10 years
delta_fu_per_patient_10y <- function(p_shorter, p_longer, m_shorter = 1, m_longer = 1) {
  p_shorter * m_shorter - p_longer * m_longer
}

# CADx device price is article-based.
# Device life is adapted here to 10 years.
pv_cadx_device_cost <- function(discount,
                                scenario_years,
                                cadx_device_capex_usd,
                                cadx_device_life_years = 10) {
  yrs <- seq_len(min(scenario_years, cadx_device_life_years))
  sum((cadx_device_capex_usd / cadx_device_life_years) / (1 + discount)^yrs)
}

fmt_num <- function(x, accuracy = 0.01) {
  ifelse(is.na(x), "N/A", scales::number(x, accuracy = accuracy, big.mark = ","))
}

fmt_dollar_na <- function(x, accuracy = 1) {
  ifelse(is.na(x), "N/A", scales::dollar(x, accuracy = accuracy))
}

