# -----------------------------
# 3) INPUTS YOU CONTROL
# -----------------------------
countries <- c("US", "UK", "JAPAN", "NORWAY")

# CADx device price ($48,814) is taken from the published study.
# Device life is adapted here to 10 years.
# Confidence is not directly parameterised for LIS and DISCARD_LITE in this script.
# Any confidence effect is implicit through the observed OD resource-use and surveillance inputs.
cadx_device_capex_usd <- 48814
cadx_device_life_years <- 10

# CO2e factors (kg CO2e/item)
co2e_per_snare     <- 0.41
co2e_per_trap      <- 0.37
co2e_per_jar       <- 0.29
co2e_cadx_per_proc <- 0.311

# Carbon cost $/kg CO2e
carbon_cost_per_kg <- 0.10

# Unit costs
unit_costs <- tribble(
  ~country, ~snare_cost, ~trap_cost, ~jar_cost,
  "US",     35,          25,         65,
  "UK",     25,          18,         45,
  "JAPAN",  30,          20,         50,
  "NORWAY", 28,          20,         55
) %>%
  mutate(country = norm_country(country))

# OD resource-use rates (per procedure) for LIS and DISCARD-lite.
# Article-aligned downstream operational consequences.
od_resource_rates <- tribble(
  ~od_strategy,     ~provider, ~jars_per_proc, ~polypectomy_rate,
  "TOTAL_REMOVAL",  "REF",     1.51,           0.58,
  "LIS",            "CADX",    1.12,           0.48,
  "LIS",            "ENDO",    1.18,           0.50,
  "DISCARD_LITE",   "CADX",    0.37,           0.48,
  "DISCARD_LITE",   "ENDO",    0.52,           0.50
) %>%
  mutate(
    od_strategy = norm_strategy(od_strategy),
    provider = norm_provider(provider)
  )

# RAD-normal parameters.
# RAD_NORMAL remains a modelling construct here.
# It includes confidence explicitly through p_high_conf.
rad_params <- list(
  diminutive_polyps_per_proc = 1.51,
  p_high_conf = 0.894,
  polypectomy_rate = 0.58,
  jars_baseline_total_removal = 1.51
)

# -----------------------------
# 4) SURVEILLANCE EFFECTS (Supplement Table 8s, N=1,134)
# Table 8s surveillance reclassification is interpreted as a 10-year effect.
# We annualise it over 10 years and apply it only over the first 10 years of the model horizon.
# LIS and DISCARD_LITE are article-derived.
# RAD_NORMAL is an assumption here: it uses the same shorter/longer surveillance effects as DISCARD_LITE.
# -----------------------------
N <- 1134

surv_table8 <- tribble(
  ~country, ~od_strategy,      ~provider, ~p_shorter, ~p_longer,

  "US",     "LIS",             "CADX",    4/N,        7/N,
  "US",     "LIS",             "ENDO",    3/N,        6/N,
  "UK",     "LIS",             "CADX",    0/N,        2/N,
  "UK",     "LIS",             "ENDO",    0/N,        2/N,
  "JAPAN",  "LIS",             "CADX",    22/N,       10/N,
  "JAPAN",  "LIS",             "ENDO",    17/N,       8/N,
  "NORWAY", "LIS",             "CADX",    0/N,        1/N,
  "NORWAY", "LIS",             "ENDO",    0/N,        1/N,

  "US",     "DISCARD_LITE",    "CADX",    55/N,       9/N,
  "US",     "DISCARD_LITE",    "ENDO",    49/N,       9/N,
  "UK",     "DISCARD_LITE",    "CADX",    5/N,        1/N,
  "UK",     "DISCARD_LITE",    "ENDO",    5/N,        2/N,
  "JAPAN",  "DISCARD_LITE",    "CADX",    47/N,       10/N,
  "JAPAN",  "DISCARD_LITE",    "ENDO",    39/N,       9/N,
  "NORWAY", "DISCARD_LITE",    "CADX",    7/N,        1/N,
  "NORWAY", "DISCARD_LITE",    "ENDO",    6/N,        1/N
) %>%
  mutate(
    country = norm_country(country),
    od_strategy = norm_strategy(od_strategy),
    provider = norm_provider(provider)
  )

# RAD_NORMAL copied from DISCARD_LITE as a modelling assumption
surv_rad_normal <- surv_table8 %>%
  filter(od_strategy == "DISCARD_LITE") %>%
  mutate(od_strategy = "RAD_NORMAL")

surv_all <- bind_rows(surv_table8, surv_rad_normal)

# -----------------------------
# 5) OD ARMS
# -----------------------------
od_arms <- tribble(
  ~od_strategy,    ~provider, ~uses_cadx,
  "RAD_NORMAL",    "ENDO",    FALSE,
  "RAD_NORMAL",    "CADX",    TRUE,
  "LIS",           "ENDO",    FALSE,
  "LIS",           "CADX",    TRUE,
  "DISCARD_LITE",  "ENDO",    FALSE,
  "DISCARD_LITE",  "CADX",    TRUE
) %>%
  mutate(
    od_strategy = norm_strategy(od_strategy),
    provider = norm_provider(provider)
  )

# -----------------------------
# 6) CORE COSTING FUNCTION
# -----------------------------
calc_od_costs <- function(base_row, country, od_strategy, provider, uses_cadx) {
  country <- norm_country(country)
  od_strategy <- norm_strategy(od_strategy)
  provider <- norm_provider(provider)

  annual_volume <- base_row[[col_annual_vol]]
  years         <- base_row[[col_years]]
  discount      <- base_row[[col_discount]]
  fu_cost       <- base_row[[col_fu_cost]]
  fu_per10k0    <- base_row[[col_fu_per10k]]
  pv_device0    <- base_row[[col_pv_device]]
  arr_inc       <- base_row[[col_arr_inc]]
  arr_death     <- base_row[[col_arr_death]]

  df_pv <- pv_factor(years, discount)

  surv <- surv_all %>%
    filter(
      .data$country == country,
      .data$od_strategy == od_strategy,
      .data$provider == provider
    )

  if (nrow(surv) != 1 && od_strategy == "RAD_NORMAL") {
    surv <- surv_all %>%
      filter(
        .data$country == country,
        .data$od_strategy == "DISCARD_LITE",
        .data$provider == provider
      )
  }

  if (nrow(surv) != 1) {
    stop("Surveillance lookup failure for ", country, " / ", od_strategy, " / ", provider)
  }

  # 10-year surveillance effect
  d_fu_patient_10y <- delta_fu_per_patient_10y(
    surv$p_shorter, surv$p_longer,
    m_shorter = 1, m_longer = 1
  )
  d_fu_per10k_per_year <- (d_fu_patient_10y / 10) * 10000

  # apply changed surveillance only over first 10 years
  n_fu_years_changed <- min(years, 10L)

  annual_fu_base <- (fu_per10k0 / 1e4) * annual_volume
  annual_fu_od_changed <- ((fu_per10k0 + d_fu_per10k_per_year) / 1e4) * annual_volume

  pv_fu_od <-
    sum(annual_fu_od_changed * fu_cost / (1 + discount)^(seq_len(n_fu_years_changed))) +
    if (years > n_fu_years_changed) {
      sum(annual_fu_base * fu_cost / (1 + discount)^(seq.int(n_fu_years_changed + 1L, years)))
    } else {
      0
    }

  fu_per10k_od <- fu_per10k0 + d_fu_per10k_per_year

  pv_cadx_capex <- if (isTRUE(uses_cadx)) {
    pv_cadx_device_cost(
      discount = discount,
      scenario_years = years,
      cadx_device_capex_usd = cadx_device_capex_usd,
      cadx_device_life_years = cadx_device_life_years
    )
  } else {
    0
  }

  pv_device_od <- pv_device0 + pv_cadx_capex
  cost_main_pv <- pv_device_od + pv_fu_od

  u <- unit_costs %>% filter(.data$country == country)
  if (nrow(u) != 1) stop("Missing unit_costs for country: ", country)

  if (od_strategy %in% c("LIS", "DISCARD_LITE")) {
    rr <- od_resource_rates %>% filter(.data$od_strategy == od_strategy, .data$provider == provider)
    if (nrow(rr) != 1) stop("Missing od_resource_rates for ", od_strategy, " / ", provider)
    jars_per_proc <- rr$jars_per_proc[[1]]
    polyp_rate    <- rr$polypectomy_rate[[1]]
  } else if (od_strategy == "RAD_NORMAL") {
    polyp_rate <- rad_params$polypectomy_rate
    saved_jars <- rad_params$p_high_conf * rad_params$diminutive_polyps_per_proc
    jars_per_proc <- max(rad_params$jars_baseline_total_removal - saved_jars, 0)
  } else {
    stop("Unknown od_strategy: ", od_strategy)
  }

  annual_procs <- annual_volume
  annual_polypectomies <- polyp_rate * annual_procs

  annual_snares <- annual_polypectomies
  annual_traps  <- annual_polypectomies
  annual_jars   <- jars_per_proc * annual_procs

  annual_polyp_mgmt_cost <-
    annual_snares * u$snare_cost +
    annual_traps * u$trap_cost +
    annual_jars * u$jar_cost

  pv_polyp_mgmt_cost <- annual_polyp_mgmt_cost * df_pv

  annual_co2_items <-
    annual_snares * co2e_per_snare +
    annual_traps * co2e_per_trap +
    annual_jars * co2e_per_jar

  annual_co2_cadx  <- if (isTRUE(uses_cadx)) annual_procs * co2e_cadx_per_proc else 0
  annual_co2_total <- annual_co2_items + annual_co2_cadx
  pv_co2_cost <- (annual_co2_total * carbon_cost_per_kg) * df_pv

  cost_extended_pv <- cost_main_pv + pv_polyp_mgmt_cost + pv_co2_cost

  # Effects remain inherited from sourced baseline CADe scenario.
  # OD management changes costs and surveillance burden, not ARR inputs, in this overlay.
  total_cols_over_horizon <- annual_volume * years
  crc_prevented   <- arr_inc   * total_cols_over_horizon
  death_prevented <- arr_death * total_cols_over_horizon

  tibble(
    Country = country,
    Scenario = base_row[[col_scenario]],
    OD_strategy = od_strategy,
    Provider = provider,
    Uses_CADx = uses_cadx,

    p_shorter = surv$p_shorter,
    p_longer  = surv$p_longer,

    FU_per10k_base = fu_per10k0,
    FU_per10k_od   = fu_per10k_od,

    PV_device_base = pv_device0,
    PV_cadx_capex  = pv_cadx_capex,
    PV_fu_od       = pv_fu_od,

    Main_cost_PV = cost_main_pv,

    jars_per_proc = jars_per_proc,
    polypectomy_rate = polyp_rate,
    PV_polyp_mgmt_cost = pv_polyp_mgmt_cost,
    PV_co2_cost = pv_co2_cost,

    Extended_cost_PV = cost_extended_pv,

    CRC_prevented = crc_prevented,
    Deaths_prevented = death_prevented,

    ICER_main_cost_per_CRC = safe_divide(Main_cost_PV, CRC_prevented),
    ICER_extended_cost_per_CRC = safe_divide(Extended_cost_PV, CRC_prevented)
  )
}

# -----------------------------
# 7) RUN ALL OD ARMS
# -----------------------------
od_results <- baseline_tbl %>%
  split(seq_len(nrow(.))) %>%
  map_dfr(function(row_df) {
    base_row <- row_df[1, ]
    expand_grid(country = countries, od_arms) %>%
      pmap_dfr(function(country, od_strategy, provider, uses_cadx) {
        calc_od_costs(base_row, country, od_strategy, provider, uses_cadx)
      })
  })

# -----------------------------
# 8) SUMMARIES
# -----------------------------
summary_main <- od_results %>%
  select(
    Country, Scenario, OD_strategy, Provider, Uses_CADx,
    Main_cost_PV, ICER_main_cost_per_CRC,
    FU_per10k_od, PV_cadx_capex
  ) %>%
  arrange(Country, Scenario, OD_strategy, Provider)

summary_extended <- od_results %>%
  select(
    Country, Scenario, OD_strategy, Provider, Uses_CADx,
    Extended_cost_PV, ICER_extended_cost_per_CRC,
    PV_polyp_mgmt_cost, PV_co2_cost, jars_per_proc, polypectomy_rate
  ) %>%
  arrange(Country, Scenario, OD_strategy, Provider)

rad_discard_breakdown <- od_results %>%
  filter(OD_strategy %in% c("RAD_NORMAL", "DISCARD_LITE")) %>%
  mutate(
    note = ifelse(
      OD_strategy == "RAD_NORMAL",
      "RAD-normal is a modelling assumption in this script. Jars are reduced by high-confidence diminutive polyps, and surveillance shorter/longer effects are assumed equal to DISCARD-lite.",
      "DISCARD-lite inputs and surveillance shorter/longer counts are article-derived."
    )
  ) %>%
  select(
    Country, Scenario, OD_strategy, Provider, Uses_CADx,
    p_shorter, p_longer, FU_per10k_od,
    jars_per_proc, polypectomy_rate,
    PV_polyp_mgmt_cost, PV_co2_cost, PV_cadx_capex,
    Main_cost_PV, Extended_cost_PV, note
  )

# -----------------------------
# 9) SIMPLE CRC TABLES
# -----------------------------
simple_crc_table <- od_results %>%
  mutate(
    OD_strategy = recode(
      OD_strategy,
      "RAD_NORMAL" = "RAD",
      "DISCARD_LITE" = "DISCARD-lite",
      "LIS" = "LIS"
    ),
    Arm = case_when(
      Provider == "ENDO" ~ "CADe_only",
      Provider == "CADX" ~ "CADe_plus_CADx",
      TRUE ~ Provider
    )
  ) %>%
  select(
    Scenario,
    Country,
    OD_strategy,
    Arm,
    CRC_prevented,
    Main_cost_PV,
    Extended_cost_PV,
    ICER_main_cost_per_CRC,
    ICER_extended_cost_per_CRC
  ) %>%
  pivot_wider(
    names_from = Arm,
    values_from = c(
      CRC_prevented,
      Main_cost_PV,
      Extended_cost_PV,
      ICER_main_cost_per_CRC,
      ICER_extended_cost_per_CRC
    )
  ) %>%
  mutate(
    Incremental_CADx_main_cost =
      Main_cost_PV_CADe_plus_CADx - Main_cost_PV_CADe_only,
    Incremental_CADx_extended_cost =
      Extended_cost_PV_CADe_plus_CADx - Extended_cost_PV_CADe_only,
    Incremental_CADx_main_cost_per_CRC =
      safe_divide(Incremental_CADx_main_cost, CRC_prevented_CADe_only),
    Incremental_CADx_extended_cost_per_CRC =
      safe_divide(Incremental_CADx_extended_cost, CRC_prevented_CADe_only)
  ) %>%
  rename(
    CRC_prevented = CRC_prevented_CADe_only
  ) %>%
  select(
    Scenario,
    Country,
    OD_strategy,
    CRC_prevented,
    Main_cost_PV_CADe_only,
    Main_cost_PV_CADe_plus_CADx,
    Incremental_CADx_main_cost,
    ICER_main_cost_per_CRC_CADe_only,
    ICER_main_cost_per_CRC_CADe_plus_CADx,
    Incremental_CADx_main_cost_per_CRC,
    Extended_cost_PV_CADe_only,
    Extended_cost_PV_CADe_plus_CADx,
    Incremental_CADx_extended_cost,
    ICER_extended_cost_per_CRC_CADe_only,
    ICER_extended_cost_per_CRC_CADe_plus_CADx,
    Incremental_CADx_extended_cost_per_CRC
  ) %>%
  arrange(Scenario, Country, OD_strategy)

# optional consistency check
stopifnot(
