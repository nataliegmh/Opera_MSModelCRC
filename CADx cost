# 9B) COMPARE OD ARMS AGAINST NO OPTICAL DIAGNOSIS
# -----------------------------
baseline_no_od <- tidyr::expand_grid(
  Country = as.character(norm_country(countries)),
  baseline_tbl
) %>%
  dplyr::transmute(
    Country = Country,
    Scenario = .data[[col_scenario]],
    No_OD_FU_per10k = .data[[col_fu_per10k]],
    No_OD_PV_device = .data[[col_pv_device]],
    No_OD_fu_cost = .data[[col_fu_cost]],
    No_OD_annual_volume = .data[[col_annual_vol]],
    No_OD_years = .data[[col_years]],
    No_OD_discount = .data[[col_discount]],
    No_OD_arr_inc = .data[[col_arr_inc]],
    No_OD_arr_death = .data[[col_arr_death]]
  ) %>%
  dplyr::distinct(Country, Scenario, .keep_all = TRUE)

baseline_no_od <- baseline_no_od %>%
  dplyr::mutate(
    No_OD_df_pv = mapply(pv_factor, No_OD_years, No_OD_discount),
    No_OD_annual_fu = (No_OD_FU_per10k / 10000) * No_OD_annual_volume,
    No_OD_PV_fu = No_OD_annual_fu * No_OD_fu_cost * No_OD_df_pv,
    No_OD_Main_cost_PV = No_OD_PV_device + No_OD_PV_fu
  )

baseline_no_od <- baseline_no_od %>%
  dplyr::left_join(
    unit_costs %>%
      dplyr::mutate(Country = as.character(norm_country(country))) %>%
      dplyr::select(Country, snare_cost, trap_cost, jar_cost),
    by = "Country"
  ) %>%
  dplyr::mutate(
    baseline_polypectomy_rate = 0.58,
    baseline_jars_per_proc = 1.51,
    baseline_annual_polypectomies = baseline_polypectomy_rate * No_OD_annual_volume,
    baseline_annual_snares = baseline_annual_polypectomies,
    baseline_annual_traps = baseline_annual_polypectomies,
    baseline_annual_jars = baseline_jars_per_proc * No_OD_annual_volume,
    baseline_annual_polyp_mgmt_cost =
      baseline_annual_snares * snare_cost +
      baseline_annual_traps * trap_cost +
      baseline_annual_jars * jar_cost,
    No_OD_PV_polyp_mgmt_cost = baseline_annual_polyp_mgmt_cost * No_OD_df_pv,
    baseline_annual_co2 =
      baseline_annual_snares * co2e_per_snare +
      baseline_annual_traps * co2e_per_trap +
      baseline_annual_jars * co2e_per_jar,
    No_OD_PV_co2_cost = (baseline_annual_co2 * carbon_cost_per_kg) * No_OD_df_pv,
    No_OD_Extended_cost_PV =
      No_OD_Main_cost_PV + No_OD_PV_polyp_mgmt_cost + No_OD_PV_co2_cost,
    No_OD_CRC_prevented = No_OD_arr_inc * (No_OD_annual_volume * No_OD_years),
    No_OD_Deaths_prevented = No_OD_arr_death * (No_OD_annual_volume * No_OD_years)
  )

od_vs_no_od <- od_results %>%
  dplyr::left_join(
    baseline_no_od %>%
      dplyr::select(
        Country, Scenario,
