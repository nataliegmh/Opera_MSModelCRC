    Incremental_extended_cost_vs_No_OD =
      Extended_cost_PV - No_OD_Extended_cost_PV,
    Incremental_CRC_prevented_vs_No_OD =
      CRC_prevented - No_OD_CRC_prevented,
    Incremental_deaths_prevented_vs_No_OD =
      Deaths_prevented - No_OD_Deaths_prevented,
    Incremental_main_cost_per_CRC_vs_No_OD =
      safe_divide(Incremental_main_cost_vs_No_OD, Incremental_CRC_prevented_vs_No_OD),
    Incremental_extended_cost_per_CRC_vs_No_OD =
      safe_divide(Incremental_extended_cost_vs_No_OD, Incremental_CRC_prevented_vs_No_OD)
  ) %>%
  dplyr::arrange(Scenario, Country, OD_strategy, Provider, Uses_CADx)

