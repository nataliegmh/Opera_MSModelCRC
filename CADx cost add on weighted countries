    CADe_plus_CADx_main_cost_per_CRC = fmt_dollar_na(CADe_plus_CADx_main_cost_per_CRC, 1),
    Incremental_CADx_main_cost_per_CRC = fmt_dollar_na(Incremental_CADx_main_cost_per_CRC, 1),
    CADe_only_extended_cost_per_CRC = fmt_dollar_na(CADe_only_extended_cost_per_CRC, 1),
    CADe_plus_CADx_extended_cost_per_CRC = fmt_dollar_na(CADe_plus_CADx_extended_cost_per_CRC, 1),
    Incremental_CADx_extended_cost_per_CRC = fmt_dollar_na(Incremental_CADx_extended_cost_per_CRC, 1)
  )

