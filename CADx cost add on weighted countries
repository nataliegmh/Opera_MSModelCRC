# -----------------------------
# D) COSTING FUNCTION USING POOLED SURVEILLANCE
# Country-specific costs are retained.
# Surveillance movement is pooled across countries.
# -----------------------------
calc_od_costs_pooled_surv <- function(base_row, country, od_strategy, provider, uses_cadx) {

  country <- as.character(norm_country(country))[1]
  od_strategy <- as.character(norm_strategy(od_strategy))[1]
  provider <- as.character(norm_provider(provider))[1]

  annual_volume <- base_row[[col_annual_vol]]
  years         <- base_row[[col_years]]
  discount      <- base_row[[col_discount]]
  fu_cost       <- base_row[[col_fu_cost]]
  fu_per10k0    <- base_row[[col_fu_per10k]]
  pv_device0    <- base_row[[col_pv_device]]
  arr_inc       <- base_row[[col_arr_inc]]
  arr_death     <- base_row[[col_arr_death]]

  df_pv <- pv_factor(years, discount)

  surv <- surv_all_pooled[
    surv_all_pooled$od_strategy == od_strategy &
      surv_all_pooled$provider == provider,
    ,
    drop = FALSE
  ]

  if (nrow(surv) != 1) {
    stop("Pooled surveillance lookup failure for ", od_strategy, " / ", provider)
  }

  d_fu_patient_10y     <- delta_fu_per_patient_10y(surv$p_shorter, surv$p_longer, m_shorter = 1, m_longer = 1)
  d_fu_per10k_per_year <- (d_fu_patient_10y / 10) * 10000
  n_fu_years_changed   <- min(years, 10L)

  annual_fu_base       <- (fu_per10k0 / 10000) * annual_volume
  annual_fu_od_changed <- ((fu_per10k0 + d_fu_per10k_per_year) / 10000) * annual_volume

  pv_fu_od <- sum(
    annual_fu_od_changed * fu_cost / (1 + discount)^(seq_len(n_fu_years_changed))
  ) + if (years > n_fu_years_changed) {
    sum(
      annual_fu_base * fu_cost / (1 + discount)^(seq.int(n_fu_years_changed + 1L, years))
    )
  } else {
    0
  }

  fu_per10k_od <- fu_per10k0 + d_fu_per10k_per_year

  pv_cadx_capex <- if (isTRUE(uses_cadx)) {
    pv_cadx_device_cost(
      discount = discount,
      scenario_years = years,
      cadx_device_capex_usd = cadx_device_capex_usd,
      cadx_device_life_years = cadx_device_life_years
    )
  } else {
    0
  }

  pv_device_od <- pv_device0 + pv_cadx_capex
  cost_main_pv <- pv_device_od + pv_fu_od

  u <- unit_costs[
    unit_costs$country == country,
    ,
    drop = FALSE
  ]

  if (nrow(u) != 1) {
    stop("Missing unit_costs for country: ", country)
  }

  if (od_strategy %in% c("LIS", "DISCARD_LITE")) {
    rr <- od_resource_rates[
      od_resource_rates$od_strategy == od_strategy &
        od_resource_rates$provider == provider,
      ,
      drop = FALSE
    ]

    if (nrow(rr) != 1) {
      stop("Missing od_resource_rates for ", od_strategy, " / ", provider)
    }

    jars_per_proc <- rr$jars_per_proc[[1]]
    polyp_rate    <- rr$polypectomy_rate[[1]]

  } else if (identical(od_strategy, "RAD_NORMAL")) {
    rp <- rad_params[
      rad_params$provider == provider,
      ,
      drop = FALSE
    ]

    if (nrow(rp) != 1) {
      stop("Missing rad_params for provider: ", provider)
    }

    polyp_rate <- rp$polypectomy_rate[[1]]

    eligible_polyps   <- rp$eligible_diminutive_polyps_per_proc[[1]]
    noneligible_jars  <- rp$noneligible_jars_per_proc[[1]]
    p_avoid_pathology <- rp$p_avoid_pathology[[1]]

    jars_per_proc <- noneligible_jars + eligible_polyps * (1 - p_avoid_pathology)

  } else {
    stop("Unknown od_strategy: ", od_strategy)
  }

  annual_procs         <- annual_volume
  annual_polypectomies <- polyp_rate * annual_procs
  annual_snares        <- annual_polypectomies
  annual_traps         <- annual_polypectomies
  annual_jars          <- jars_per_proc * annual_procs

  annual_polyp_mgmt_cost <- annual_snares * u$snare_cost +
    annual_traps * u$trap_cost +
    annual_jars * u$jar_cost

  pv_polyp_mgmt_cost <- annual_polyp_mgmt_cost * df_pv

  annual_co2_items <- annual_snares * co2e_per_snare +
    annual_traps * co2e_per_trap +
    annual_jars * co2e_per_jar

  annual_co2_cadx <- if (isTRUE(uses_cadx)) {
    annual_procs * co2e_cadx_per_proc
  } else {
    0
  }

  annual_co2_total <- annual_co2_items + annual_co2_cadx
  pv_co2_cost      <- (annual_co2_total * carbon_cost_per_kg) * df_pv
  cost_extended_pv <- cost_main_pv + pv_polyp_mgmt_cost + pv_co2_cost

  total_cols_over_horizon <- annual_volume * years
  crc_prevented           <- arr_inc * total_cols_over_horizon
  death_prevented         <- arr_death * total_cols_over_horizon

  tibble::tibble(
    Country                    = country,
    Scenario                   = base_row[[col_scenario]],
    OD_strategy                = od_strategy,
    Provider                   = provider,
    Uses_CADx                  = uses_cadx,
    p_shorter_pooled           = surv$p_shorter,
    p_longer_pooled            = surv$p_longer,
    FU_per10k_base             = fu_per10k0,
    FU_per10k_od               = fu_per10k_od,
    PV_device_base             = pv_device0,
    PV_cadx_capex              = pv_cadx_capex,
    PV_fu_od                   = pv_fu_od,
    Main_cost_PV               = cost_main_pv,
    jars_per_proc              = jars_per_proc,
    polypectomy_rate           = polyp_rate,
    PV_polyp_mgmt_cost         = pv_polyp_mgmt_cost,
    PV_co2_cost                = pv_co2_cost,
    Extended_cost_PV           = cost_extended_pv,
    CRC_prevented              = crc_prevented,
    Deaths_prevented           = death_prevented,
    ICER_main_cost_per_CRC     = safe_divide(cost_main_pv, crc_prevented),
    ICER_extended_cost_per_CRC = safe_divide(cost_extended_pv, crc_prevented)
  )
}

# -----------------------------
# E) RUN ALL OD ARMS WITH POOLED SURVEILLANCE
# -----------------------------
od_results_pooled_surv <- baseline_tbl %>%
  split(seq_len(nrow(.))) %>%
  purrr::map_dfr(function(row_df) {
    base_row <- row_df[1, ]
    tidyr::expand_grid(country = countries, od_arms) %>%
      purrr::pmap_dfr(function(country, od_strategy, provider, uses_cadx) {
        calc_od_costs_pooled_surv(base_row, country, od_strategy, provider, uses_cadx)
      })
  })

# -----------------------------
# F) SIMPLE TABLES, SAME STRUCTURE AS MAIN ANALYSIS
# -----------------------------
simple_crc_table_pooled_surv <- od_results_pooled_surv %>%
  dplyr::mutate(
    OD_strategy = dplyr::recode(
      OD_strategy,
      "RAD_NORMAL" = "RAD",
      "DISCARD_LITE" = "DISCARD-lite",
      "LIS" = "LIS"
    ),
    Arm = dplyr::case_when(
      Uses_CADx ~ "CADe_plus_CADx",
      !Uses_CADx ~ "CADe_only",
      TRUE ~ as.character(Provider)
    )
  ) %>%
  dplyr::select(
    Scenario,
    Country,
    OD_strategy,
    Arm,
    CRC_prevented,
    Main_cost_PV,
    Extended_cost_PV,
    ICER_main_cost_per_CRC,
    ICER_extended_cost_per_CRC
  ) %>%
  tidyr::pivot_wider(
    names_from = Arm,
    values_from = c(
      CRC_prevented,
      Main_cost_PV,
      Extended_cost_PV,
      ICER_main_cost_per_CRC,
      ICER_extended_cost_per_CRC
    )
  ) %>%
  dplyr::mutate(
    Incremental_CADx_main_cost =
      Main_cost_PV_CADe_plus_CADx - Main_cost_PV_CADe_only,
    Incremental_CADx_extended_cost =
      Extended_cost_PV_CADe_plus_CADx - Extended_cost_PV_CADe_only,
    Incremental_CADx_main_cost_per_CRC =
      safe_divide(Incremental_CADx_main_cost, CRC_prevented_CADe_only),
    Incremental_CADx_extended_cost_per_CRC =
      safe_divide(Incremental_CADx_extended_cost, CRC_prevented_CADe_only)
  ) %>%
  dplyr::rename(
    CRC_prevented = CRC_prevented_CADe_only
  ) %>%
  dplyr::select(
    Scenario,
    Country,
    OD_strategy,
    CRC_prevented,
    Main_cost_PV_CADe_only,
    Main_cost_PV_CADe_plus_CADx,
    Incremental_CADx_main_cost,
    ICER_main_cost_per_CRC_CADe_only,
    ICER_main_cost_per_CRC_CADe_plus_CADx,
    Incremental_CADx_main_cost_per_CRC,
    Extended_cost_PV_CADe_only,
    Extended_cost_PV_CADe_plus_CADx,
    Incremental_CADx_extended_cost,
    ICER_extended_cost_per_CRC_CADe_only,
    ICER_extended_cost_per_CRC_CADe_plus_CADx,
    Incremental_CADx_extended_cost_per_CRC
  ) %>%
  dplyr::arrange(Scenario, Country, OD_strategy)

# -----------------------------
# G) HEADLINE POOLED-ACROSS-COUNTRY SUMMARY
# This gives you one estimate per scenario and strategy.
# It averages the country-specific outputs using the same weights.
# -----------------------------
country_cost_weights <- tibble::tibble(
  Country = names(pooled_country_weights),
  country_weight = as.numeric(pooled_country_weights)
)

headline_pooled_summary <- simple_crc_table_pooled_surv %>%
  dplyr::left_join(country_cost_weights, by = "Country") %>%
  dplyr::group_by(Scenario, OD_strategy) %>%
  dplyr::summarise(
    countries_included = paste(sort(unique(Country)), collapse = ", "),
    pooling_method = "Weighted mean across country scenarios",
    CRC_prevented = stats::weighted.mean(CRC_prevented, w = country_weight, na.rm = TRUE),
    CADe_only_main_cost_per_CRC =
      stats::weighted.mean(ICER_main_cost_per_CRC_CADe_only, w = country_weight, na.rm = TRUE),
    CADe_plus_CADx_main_cost_per_CRC =
      stats::weighted.mean(ICER_main_cost_per_CRC_CADe_plus_CADx, w = country_weight, na.rm = TRUE),
    Incremental_CADx_main_cost_per_CRC =
      stats::weighted.mean(Incremental_CADx_main_cost_per_CRC, w = country_weight, na.rm = TRUE),
    CADe_only_extended_cost_per_CRC =
      stats::weighted.mean(ICER_extended_cost_per_CRC_CADe_only, w = country_weight, na.rm = TRUE),
    CADe_plus_CADx_extended_cost_per_CRC =
      stats::weighted.mean(ICER_extended_cost_per_CRC_CADe_plus_CADx, w = country_weight, na.rm = TRUE),
    Incremental_CADx_extended_cost_per_CRC =
      stats::weighted.mean(Incremental_CADx_extended_cost_per_CRC, w = country_weight, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  dplyr::arrange(Scenario, OD_strategy)

headline_pooled_summary_fmt <- headline_pooled_summary %>%
