mw_slice_baseline_except <- function(scn_name, except_field) {
  b <- dplyr::filter(baseline_by_scn, Scenario == scn_name) %>% dplyr::slice(1)
  d <- expanded_mw_mean_tbl %>% dplyr::filter(Scenario == scn_name)
  
  fields <- c("device_cost","annual_volume","life_years","discount","fu_cost",
              "fu_per10k","risk_inc_no","risk_inc_with","risk_death_no","risk_death_with")
  keep_baseline <- setdiff(fields, except_field)
  
  for (f in keep_baseline) {
    d <- d %>% dplyr::filter(.data[[f]] == b[[f]])
  }
  d
}

