#### 9) EXPANDED CEA: treatment savings, polyp cost, CO2 cost ####
delta_ppc_tbl <- tibble(
  Scenario = c("Screening colonoscopy", "FIT-positive colonoscopy"),
  delta_ppc = c(0.35, 0.35)
)

cea_crc_expansions_tbl <- baseline_tbl %>%
  left_join(delta_ppc_tbl, by = "Scenario") %>%
  rowwise() %>%
  mutate(
    df = sum(1 / (1 + discount)^seq_len(life_years)),
    # PV terms (same horizon/discounting convention as the program costs)
    pv_crc_savings = cost_crc_local   * arr_incidence * annual_volume * df,
    pv_polyp       = cost_polyp_local * delta_ppc     * annual_volume * df,
    # additional follow-ups induced by CADe (per year)
    annual_fu = (fu_per10k / 1e4) * annual_volume,
    # Incremental CO2 due to CADe adoption:
    #  (1) device-use emissions on all baseline CADe colonoscopies
    #  (2) emissions from additional follow-up colonoscopies induced by CADe
    pv_co2 = cost_co2_local * (annual_volume * cade_device_co2e_local +
                                 annual_fu * colonoscopy_co2e_local) * df,
    cost_per_crc_prevented_treatment =
      safe_divide(pv_device + pv_followup - pv_crc_savings, crc_prevented),
    cost_per_crc_prevented_polyp =
      safe_divide(pv_device + pv_followup + pv_polyp, crc_prevented),
    cost_per_crc_prevented_co2 =
      safe_divide(pv_device + pv_followup + pv_co2, crc_prevented),
    cost_per_crc_prevented_all =
      safe_divide(pv_device + pv_followup + pv_polyp + pv_co2 - pv_crc_savings, crc_prevented)
  ) %>%
  ungroup() %>%
  select(
    Scenario,
    cost_per_crc_prevented_treatment,
    cost_per_crc_prevented_polyp,
    cost_per_crc_prevented_co2,
    cost_per_crc_prevented_all
  )

cea_crc_expansions_fmt <- cea_crc_expansions_tbl %>%
  mutate(across(starts_with("cost_per_crc_prevented"), ~ fmt_dollar_na(.x, accuracy = 1)))

#### 9b) EXPANDED ANALYSIS FUNCTION FOR STEPWISE MINâ€“MAX + BEST/WORST ####
analyse_expanded <- function(sc,
                             cost_crc   = cost_crc_local,
                             cost_polyp = cost_polyp_local,
                             delta_ppc  = 0.35,
                             cost_co2   = cost_co2_local,
                             colonoscopy_co2e = colonoscopy_co2e_local,
                             cade_device_co2e = cade_device_co2e_local) {
  base <- analyse(sc)
  df <- sum(1 / (1 + sc$discount)^seq_len(sc$life_years))
  V  <- sc$annual_volume
  annual_fu <- (sc$fu_per10k / 1e4) * sc$annual_volume
  
  pv_crc_savings <- cost_crc   * base$arr_incidence * V * df
  pv_polyp       <- cost_polyp * delta_ppc          * V * df
  # Incremental CO2 due to CADe adoption (device-use + additional FU)
  pv_co2 <- cost_co2 * (V * cade_device_co2e + annual_fu * colonoscopy_co2e) * df
  
  pv_device   <- base$pv_device
  pv_followup <- base$pv_followup
  
  # cumulative PV costs by step
  pv_step1 <- pv_device
  pv_step2 <- pv_device + pv_followup
  pv_step3 <- pv_device + pv_followup - pv_crc_savings
  pv_step4 <- pv_device + pv_followup - pv_crc_savings + pv_polyp
  pv_step5 <- pv_device + pv_followup - pv_crc_savings + pv_polyp + pv_co2
  
  tibble(
    Scenario = sc$name,
    crc_prevented = base$crc_prevented,
    c1 = safe_divide(pv_step1, base$crc_prevented),
    c2 = safe_divide(pv_step2, base$crc_prevented),
    c3 = safe_divide(pv_step3, base$crc_prevented),
    c4 = safe_divide(pv_step4, base$crc_prevented),
    c5 = safe_divide(pv_step5, base$crc_prevented)
  )
}

