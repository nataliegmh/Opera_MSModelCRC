## 5b) risk ARR CIs
compute_ce_for_delta <- function(sc0, delta_inc = NULL, delta_death = NULL) {
  sc_mod <- sc0
  if (!is.null(delta_inc))   sc_mod$inc_with   <- pmax(sc0$inc_no   - delta_inc,   0)
  if (!is.null(delta_death)) sc_mod$death_with <- pmax(sc0$death_no - delta_death, 0)
  analyse(sc_mod)
}

owsa_risk <- map_dfr(scenarios, function(sc0) {
  r <- dplyr::filter(arr_ci, ScenarioName == sc0$name)
  if (nrow(r) == 0) return(tibble())
  r <- r[1, ]
  
  bind_rows(
    compute_ce_for_delta(sc0, delta_inc = r$Delta_inc_lo) %>%
      transmute(Scenario = sc0$name, Parameter = "ARR: CRC incidence", Case = "Low (CI)", Value = r$Delta_inc_lo,
                `Total cost per CRC prevented`       = fmt_dollar_na(cost_per_crc_prevented, 1),
                `Total cost per CRC death prevented` = fmt_dollar_na(cost_per_death_prevented, 1)),
