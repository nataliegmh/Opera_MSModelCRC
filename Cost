  cp_min   <- ce_for(cp_vals["min"],  dppc_vals["mean"])
  cp_mean  <- ce_for(cp_vals["mean"], dppc_vals["mean"])
  cp_max   <- ce_for(cp_vals["max"],  dppc_vals["mean"])
  dppc_min <- ce_for(cp_vals["mean"], dppc_vals["min"])
