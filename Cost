#### 10) POLYP OWSA (Supplementary table): vary COSTpol and Î”PPC ####
supp_polyp_tbl <- map_dfr(seq_len(nrow(baseline_tbl)), function(i) {
  sc <- baseline_tbl[i, ]
  df <- sum(1 / (1 + sc$discount)^seq_len(sc$life_years))
  V  <- sc$annual_volume
  base_cost <- sc$pv_device + sc$pv_followup
  
  ce_for <- function(cost_pol, delta_ppc) {
    pv_polyp <- cost_pol * delta_ppc * V * df
    total_cost <- base_cost + pv_polyp
    list(
      cost_crc   = safe_divide(total_cost, sc$crc_prevented),
      cost_death = safe_divide(total_cost, sc$death_prevented)
    )
  }
  
  cp_vals   <- polyp_cost_range
  dppc_vals <- delta_ppc_range
  
  cp_min  <- ce_for(cp_vals["min"],  dppc_vals["mean"])
  cp_mean <- ce_for(cp_vals["mean"], dppc_vals["mean"])
  cp_max  <- ce_for(cp_vals["max"],  dppc_vals["mean"])
  dppc_min  <- ce_for(cp_vals["mean"], dppc_vals["min"])
  dppc_mean <- ce_for(cp_vals["mean"], dppc_vals["mean"])
  dppc_max  <- ce_for(cp_vals["mean"], dppc_vals["max"])
  
  tibble(
    Scenario  = rep(sc$Scenario, 2),
    Parameter = c("Cost of polyp removal per colonoscopy", "Î”PPC"),
    Input_Min  = c(cp_vals["min"],   dppc_vals["min"]),
    Input_Mean = c(cp_vals["mean"],  dppc_vals["mean"]),
    Input_Max  = c(cp_vals["max"],   dppc_vals["max"]),
    Cost_per_CRC_Min    = c(cp_min$cost_crc,   dppc_min$cost_crc),
    Cost_per_CRC_Mean   = c(cp_mean$cost_crc,  dppc_mean$cost_crc),
    Cost_per_CRC_Max    = c(cp_max$cost_crc,   dppc_max$cost_crc),
    Cost_per_death_Min  = c(cp_min$cost_death,   dppc_min$cost_death),
    Cost_per_death_Mean = c(cp_mean$cost_death,  dppc_mean$cost_death),
    Cost_per_death_Max  = c(cp_max$cost_death,   dppc_max$cost_death)
  )
})

