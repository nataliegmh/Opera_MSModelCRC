    total_cost <- base_cost + pv_polyp
    list(
      cost_crc   = safe_divide(total_cost, sc$crc_prevented),
      cost_death = safe_divide(total_cost, sc$death_prevented)
    )
  }
  
  cp_vals   <- polyp_cost_range
