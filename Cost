#### POST-RUN BLOCK: EXPANDED MWSA EXTREMES (GLOBAL MIN/MAX c5)
#### Produces: plot PNG/PDF + separate Excel workbook
#### Requires: your main script has already run and created multiway_tbl, scenarios, analyse_expanded(), ranges
#### =========================================================

# Safety checks (fail fast if something is missing)
stopifnot(
  exists("multiway_tbl"),
  exists("scenarios"),
  exists("analyse_expanded"),
  exists("safe_divide"),
  exists("fmt_dollar_na"),
  exists("cost_crc_range"),
  exists("polyp_cost_range"),
  exists("delta_ppc_range"),
  exists("cost_co2_range"),
  exists("colonoscopy_co2e_range"),
  exists("cade_device_co2e_range")
)

# ---- discount factor helper (same end-of-year convention as analyse())
df_discount_scalar <- function(discount, life_years) {
  sum(1 / (1 + discount)^seq_len(life_years))
}

# ---- expansion extremes (from your ranges)
exp_extremes <- list(
  # MINIMISE c5: maximise savings, minimise added costs
  min = list(
    cost_crc   = unname(cost_crc_range["max"]),
    cost_polyp = unname(polyp_cost_range["min"]),
    delta_ppc  = unname(delta_ppc_range["min"]),
    cost_co2   = unname(cost_co2_range["min"]),
    colonoscopy_co2e = unname(colonoscopy_co2e_range["mean"]), # fixed in your script
    cade_device_co2e = unname(cade_device_co2e_range["mean"])  # fixed in your script
  ),
  # MAXIMISE c5: minimise savings, maximise added costs
  max = list(
    cost_crc   = unname(cost_crc_range["min"]),
    cost_polyp = unname(polyp_cost_range["max"]),
    delta_ppc  = unname(delta_ppc_range["max"]),
    cost_co2   = unname(cost_co2_range["max"]),
    colonoscopy_co2e = unname(colonoscopy_co2e_range["mean"]), # fixed in your script
    cade_device_co2e = unname(cade_device_co2e_range["mean"])  # fixed in your script
  )
)

# ---- Compute expanded extremes per Stage-A row (multiway_tbl)
expanded_mw_extremes_tbl <- multiway_tbl %>%
  mutate(
    df_disc   = purrr::map2_dbl(discount, life_years, df_discount_scalar),
    annual_fu = (fu_per10k / 1e4) * annual_volume,
    pv_program = pv_device + pv_followup
  ) %>%
  # MIN possible c5 for each row
  mutate(
    pv_crc_savings_min = exp_extremes$min$cost_crc * arr_incidence * annual_volume * df_disc,
    pv_polyp_min       = exp_extremes$min$cost_polyp * exp_extremes$min$delta_ppc * annual_volume * df_disc,
    pv_co2_min         = exp_extremes$min$cost_co2 *
      (annual_volume * exp_extremes$min$cade_device_co2e + annual_fu * exp_extremes$min$colonoscopy_co2e) * df_disc,
    pv_total_min = pv_program - pv_crc_savings_min + pv_polyp_min + pv_co2_min,
    c5_min_possible = safe_divide(pv_total_min, crc_prevented)
  ) %>%
  # MAX possible c5 for each row
  mutate(
    pv_crc_savings_max = exp_extremes$max$cost_crc * arr_incidence * annual_volume * df_disc,
    pv_polyp_max       = exp_extremes$max$cost_polyp * exp_extremes$max$delta_ppc * annual_volume * df_disc,
    pv_co2_max         = exp_extremes$max$cost_co2 *
      (annual_volume * exp_extremes$max$cade_device_co2e + annual_fu * exp_extremes$max$colonoscopy_co2e) * df_disc,
    pv_total_max = pv_program - pv_crc_savings_max + pv_polyp_max + pv_co2_max,
    c5_max_possible = safe_divide(pv_total_max, crc_prevented)
  )

# ---- Baseline c5 (mean expansion inputs) for dashed line in plot
baseline_c5_tbl <- purrr::map_dfr(scenarios, function(sc0) {
  analyse_expanded(
    sc0,
    cost_crc   = unname(cost_crc_range["mean"]),
    cost_polyp = unname(polyp_cost_range["mean"]),
    delta_ppc  = unname(delta_ppc_range["mean"]),
    cost_co2   = unname(cost_co2_range["mean"]),
    colonoscopy_co2e = unname(colonoscopy_co2e_range["mean"]),
    cade_device_co2e = unname(cade_device_co2e_range["mean"])
  ) %>%
    dplyr::transmute(Scenario, baseline_c5 = c5)
})

# ---- GLOBAL min and max scenarios per scenario
global_min_tbl <- expanded_mw_extremes_tbl %>%
  group_by(Scenario) %>%
  slice_min(c5_min_possible, n = 1, with_ties = FALSE) %>%
  ungroup() %>%
  mutate(Extreme = "Global MIN c5") %>%
  select(
    Scenario, Extreme,
    device_cost, fu_cost, annual_volume, life_years, discount, fu_per10k,
    risk_inc_no, risk_inc_with, risk_death_no, risk_death_with,
    crc_prevented, arr_incidence,
    pv_device, pv_followup, pv_program,
    c5_min_possible,
    pv_crc_savings_min, pv_polyp_min, pv_co2_min, pv_total_min
  ) %>%
  rename(
    c5 = c5_min_possible,
    pv_crc_savings = pv_crc_savings_min,
    pv_polyp = pv_polyp_min,
    pv_co2 = pv_co2_min,
    pv_total = pv_total_min
  )

global_max_tbl <- expanded_mw_extremes_tbl %>%
  group_by(Scenario) %>%
  slice_max(c5_max_possible, n = 1, with_ties = FALSE) %>%
  ungroup() %>%
  mutate(Extreme = "Global MAX c5") %>%
  select(
    Scenario, Extreme,
    device_cost, fu_cost, annual_volume, life_years, discount, fu_per10k,
    risk_inc_no, risk_inc_with, risk_death_no, risk_death_with,
    crc_prevented, arr_incidence,
    pv_device, pv_followup, pv_program,
    c5_max_possible,
    pv_crc_savings_max, pv_polyp_max, pv_co2_max, pv_total_max
  ) %>%
  rename(
    c5 = c5_max_possible,
    pv_crc_savings = pv_crc_savings_max,
    pv_polyp = pv_polyp_max,
    pv_co2 = pv_co2_max,
    pv_total = pv_total_max
  )

expanded_mw_global_minmax_tbl <- bind_rows(global_min_tbl, global_max_tbl) %>%
  left_join(baseline_c5_tbl, by = "Scenario") %>%
  mutate(
    c5_fmt = fmt_dollar_na(c5, 1),
    baseline_c5_fmt = fmt_dollar_na(baseline_c5, 1),
    crc_prevented_fmt = scales::number(crc_prevented, accuracy = 0.01)
  )

# ---- Plot table (min/max per scenario + baseline)
plot_global_range_tbl <- expanded_mw_global_minmax_tbl %>%
  select(Scenario, Extreme, c5) %>%
  tidyr::pivot_wider(names_from = Extreme, values_from = c5) %>%
  rename(c5_min = `Global MIN c5`, c5_max = `Global MAX c5`) %>%
  left_join(baseline_c5_tbl, by = "Scenario") %>%
  mutate(
    min_lab = fmt_dollar_na(c5_min, 1),
    max_lab = fmt_dollar_na(c5_max, 1)
  )

plot_expanded_mw_global <- ggplot(plot_global_range_tbl, aes(y = Scenario)) +
  geom_linerange(aes(xmin = c5_min, xmax = c5_max), linewidth = 1.2) +
  geom_point(aes(x = c5_min), size = 2) +
  geom_point(aes(x = c5_max), size = 2) +
  geom_text(aes(x = c5_min, label = min_lab), hjust = 1.08, size = 3) +
  geom_text(aes(x = c5_max, label = max_lab), hjust = -0.08, size = 3) +
  geom_vline(
    data = baseline_c5_tbl,
    aes(xintercept = baseline_c5),
    linetype = "dashed"
  ) +
  facet_wrap(~ Scenario, scales = "free_x") +
  scale_x_continuous(labels = scales::label_number(big.mark = ",", accuracy = 1)) +
  labs(
    x = "Expanded cost per CRC prevented (USD) [c5]",
    y = NULL,
    title = "Expanded MWSA: global MIN and MAX c5 across all factors; dashed = baseline (mean inputs)"
  ) +
  theme_bw()

ggsave("expanded_MWSA_global_minmax_c5.png", plot_expanded_mw_global, width = 11, height = 3.8, dpi = 300)
ggsave("expanded_MWSA_global_minmax_c5.pdf", plot_expanded_mw_global, width = 11, height = 3.8)

