    cost_polyp    = c(polyp_cost_range["min"], polyp_cost_range["max"]),
    delta_ppc     = c(delta_ppc_range["min"],  delta_ppc_range["max"]),
    cost_co2          = c(cost_co2_range["min"], cost_co2_range["max"]),
    colonoscopy_co2e  = c(colonoscopy_co2e_range["min"], colonoscopy_co2e_range["max"]),
    cade_device_co2e  = c(cade_device_co2e_range["min"], cade_device_co2e_range["max"])
  )
  
  res <- pmap_dfr(grid, function(device_cost, fu_cost, annual_volume, life_years, discount,
                                 cost_crc, cost_polyp, delta_ppc,
                                 cost_co2, colonoscopy_co2e, cade_device_co2e) {
    sc_mod <- sc0
    sc_mod$device_cost   <- device_cost
    sc_mod$fu_cost       <- fu_cost
    sc_mod$annual_volume <- annual_volume
    sc_mod$life_years    <- life_years
    sc_mod$discount      <- discount
    
    analyse_expanded(sc_mod,
                     cost_crc = cost_crc,
                     cost_polyp = cost_polyp,
                     delta_ppc = delta_ppc,
                     cost_co2 = cost_co2,
                     colonoscopy_co2e = colonoscopy_co2e,
                     cade_device_co2e = cade_device_co2e) %>%
      mutate(
        device_cost = device_cost, fu_cost = fu_cost, annual_volume = annual_volume,
        life_years = life_years, discount = discount,
        cost_crc = cost_crc, cost_polyp = cost_polyp, delta_ppc = delta_ppc,
        cost_co2 = cost_co2, colonoscopy_co2e = colonoscopy_co2e, cade_device_co2e = cade_device_co2e
      )
  })
  
  best <- res %>% slice_min(c5, n = 1, with_ties = FALSE) %>% mutate(Case = "Best (expanded)")
  worst <- res %>% slice_max(c5, n = 1, with_ties = FALSE) %>% mutate(Case = "Worst (expanded)")
  
  bind_rows(best, worst) %>%
    transmute(
      Scenario, Case,
      Cost_per_CRC_prevented_expanded = c5,
      Cost_per_CRC_prevented_expanded_fmt = fmt_dollar_na(c5, 1),
      device_cost, fu_cost, annual_volume, life_years, discount,
      cost_crc, cost_polyp, delta_ppc,
      cost_co2, colonoscopy_co2e, cade_device_co2e
    )
})

#### 9d) STEPWISE CUMULATIVE MINâ€“MAX (range widens as components are added) ####
stepwise_minmax_tbl <- map_dfr(scenarios, function(sc0) {
  dev_lo <- op_low("device_cost"); dev_hi <- op_high("device_cost")
  fu_lo  <- op_low("fu_cost");     fu_hi  <- op_high("fu_cost")
  
  steps <- list(
    `1) Device` = tidyr::crossing(
      device_cost = c(dev_lo, dev_hi)
    ),
    `2) + Surveillance` = tidyr::crossing(
      device_cost = c(dev_lo, dev_hi),
      fu_cost     = c(fu_lo, fu_hi)
    ),
    `3) + CRC` = tidyr::crossing(
      device_cost = c(dev_lo, dev_hi),
      fu_cost     = c(fu_lo, fu_hi),
      cost_crc    = c(cost_crc_range["min"], cost_crc_range["max"])
    ),
    `4) + Polyp` = tidyr::crossing(
      device_cost = c(dev_lo, dev_hi),
      fu_cost     = c(fu_lo, fu_hi),
      cost_crc    = c(cost_crc_range["min"], cost_crc_range["max"]),
      cost_polyp  = c(polyp_cost_range["min"], polyp_cost_range["max"]),
      delta_ppc   = c(delta_ppc_range["min"],  delta_ppc_range["max"])
    ),
    `5) + Environmental` = tidyr::crossing(
      device_cost = c(dev_lo, dev_hi),
      fu_cost     = c(fu_lo, fu_hi),
      cost_crc    = c(cost_crc_range["min"], cost_crc_range["max"]),
      cost_polyp  = c(polyp_cost_range["min"], polyp_cost_range["max"]),
      delta_ppc   = c(delta_ppc_range["min"],  delta_ppc_range["max"]),
      cost_co2    = c(cost_co2_range["min"], cost_co2_range["max"]),
      colonoscopy_co2e = c(colonoscopy_co2e_range["min"], colonoscopy_co2e_range["max"]),
      cade_device_co2e = c(cade_device_co2e_range["min"], cade_device_co2e_range["max"])
    )
  )
  
  imap_dfr(steps, function(g, step_name) {
    res <- pmap_dfr(g, function(...) {
      args <- list(...)
      sc_mod <- sc0
      if (!is.null(args$device_cost)) sc_mod$device_cost <- args$device_cost
      if (!is.null(args$fu_cost))     sc_mod$fu_cost     <- args$fu_cost
      
      analyse_expanded(
        sc_mod,
        cost_crc   = if (!is.null(args$cost_crc))   args$cost_crc   else cost_crc_range["mean"],
        cost_polyp = if (!is.null(args$cost_polyp)) args$cost_polyp else polyp_cost_range["mean"],
        delta_ppc  = if (!is.null(args$delta_ppc))  args$delta_ppc  else delta_ppc_range["mean"],
        cost_co2   = if (!is.null(args$cost_co2))   args$cost_co2   else cost_co2_range["mean"],
        colonoscopy_co2e = if (!is.null(args$colonoscopy_co2e)) args$colonoscopy_co2e else colonoscopy_co2e_range["mean"],
        cade_device_co2e = if (!is.null(args$cade_device_co2e)) args$cade_device_co2e else cade_device_co2e_range["mean"]
      )
    })
    tibble(
      Scenario = sc0$name,
      Step = step_name,
      min = min(res$c5, na.rm = TRUE),
      max = max(res$c5, na.rm = TRUE)
    )
  })
}) %>%
  mutate(
    Step = factor(Step, levels = c("1) Device", "2) + Surveillance", "3) + CRC", "4) + Polyp", "5) + Environmental"))
  
