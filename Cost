df_discount <- function(discount, life_years) {
  sum(1 / (1 + discount)^seq_len(life_years))
}

add_stepwise_costs <- function(df,
                               cost_crc   = cost_crc_range["mean"],
                               cost_polyp = polyp_cost_range["mean"],
                               delta_ppc  = delta_ppc_range["mean"],
                               cost_co2   = cost_co2_range["mean"],
                               colonoscopy_co2e = colonoscopy_co2e_range["mean"],
                               cade_device_co2e = cade_device_co2e_range["mean"]) {
  df %>%
    mutate(
      df_disc = purrr::map2_dbl(discount, life_years, df_discount),
      annual_fu = (fu_per10k / 1e4) * annual_volume,
      pv_crc_savings = cost_crc * arr_incidence * annual_volume * df_disc,
      pv_polyp       = cost_polyp * delta_ppc * annual_volume * df_disc,
      pv_co2         = cost_co2 * (annual_volume * cade_device_co2e + annual_fu * colonoscopy_co2e) * df_disc,
      pv_step1 = pv_device,
      pv_step2 = pv_device + pv_followup,
      pv_step3 = pv_step2 - pv_crc_savings,
      pv_step4 = pv_step3 + pv_polyp,
      pv_step5 = pv_step4 + pv_co2,
      c1 = safe_divide(pv_step1, crc_prevented),
      c2 = safe_divide(pv_step2, crc_prevented),
      c3 = safe_divide(pv_step3, crc_prevented),
      c4 = safe_divide(pv_step4, crc_prevented),
      c5 = safe_divide(pv_step5, crc_prevented)
    )
}

