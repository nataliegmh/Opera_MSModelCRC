param_map <- c(
  fu_cost       = "fu_cost",
  discount      = "discount",
  life_years    = "life_years",
  annual_volume = "annual_volume",
  device_cost   = "device_cost",
  cost_crc      = "cost_crc",
  cost_co2      = "cost_co2",
  cost_polyp    = "cost_polyp"
)

scenario_fields <- c("annual_volume", "device_cost", "life_years", "discount", "fu_cost")
expanded_args   <- c("cost_crc", "cost_polyp", "delta_ppc", "cost_co2", "colonoscopy_co2e", "cade_device_co2e")

defaults_expanded <- list(
  cost_crc = 55352,
  cost_polyp = 287,
  delta_ppc = delta_ppc_const,
  cost_co2 = 0.069,
  colonoscopy_co2e = colonoscopy_co2e_const,
  cade_device_co2e = cade_device_co2e_const
)

apply_baselines <- function(sc0, df_scn) {
  sc <- sc0
  args <- defaults_expanded
  for (p in intersect(names(param_map), df_scn$Parameter)) {
    mapped <- unname(param_map[[p]])
    v <- df_scn$Input_Baseline[df_scn$Parameter == p][1]
    if (is.na(v)) next
    v <- coerce_for_model(mapped, v)
    if (mapped %in% scenario_fields) sc[[mapped]] <- v
    if (mapped %in% expanded_args)   args[[mapped]] <- v
  }
  list(sc = sc, args = args)
}

apply_term_exclusions_to_args <- function(args, exclude_params) {
  if ("cost_crc" %in% exclude_params)   args$cost_crc <- 0
  if ("cost_polyp" %in% exclude_params) args$cost_polyp <- 0
  if ("cost_co2" %in% exclude_params)   args$cost_co2 <- 0
  args
}

# -----------------------------
# OWSA runner
# -----------------------------
run_owsa <- function(method = c("Endpoint", "Exhaustive"), exclude_params = character(), n_grid = 11) {
  method <- match.arg(method)
  
  map_dfr(unique(inputs$Scenario), function(scn_name) {
    df_scn <- inputs %>% filter(Scenario == scn_name)
    sc0 <- get_scenario_obj(scn_name)
    
    base_pack <- apply_baselines(sc0, df_scn)
    base_sc <- base_pack$sc
    base_args <- apply_term_exclusions_to_args(base_pack$args, exclude_params)
    
    baseline_c5 <- calc_c5(base_sc, base_args)
    
    df_rows <- df_scn %>% filter(!Parameter %in% exclude_params)
    
    map_dfr(seq_len(nrow(df_rows)), function(i) {
      row <- df_rows[i, ]
      mapped <- unname(param_map[[row$Parameter]])
      
      eval_one <- function(v) {
        v <- coerce_for_model(mapped, v)
        sc <- base_sc
        args <- base_args
        if (mapped %in% scenario_fields) sc[[mapped]] <- v
        if (mapped %in% expanded_args)   args[[mapped]] <- v
        calc_c5(sc, args)
      }
      
      if (method == "Endpoint") {
        min_c5 <- eval_one(row$Input_Min)
        max_c5 <- eval_one(row$Input_Max)
      } else {
        vals <- grid_values(mapped, row$Input_Min, row$Input_Max, n = n_grid)
        if (!length(vals)) vals <- c(row$Input_Min, row$Input_Max)
        c5_vals <- vapply(vals, eval_one, numeric(1))
        min_c5 <- min(c5_vals, na.rm = TRUE)
        max_c5 <- max(c5_vals, na.rm = TRUE)
      }
      
      low_abs  <- pmin(min_c5, max_c5, na.rm = TRUE)
      high_abs <- pmax(min_c5, max_c5, na.rm = TRUE)
      
      tibble(
        Method = method,
        Scenario = scn_name,
        Pretty = row$Pretty,
        Parameter = row$Parameter,
        baseline_c5 = baseline_c5,
        min_c5 = min_c5,
        max_c5 = max_c5,
        low_abs = low_abs,
        high_abs = high_abs
      )
    })
  })
}

# -----------------------------
# MW mean baseline (cached)
# -----------------------------
mw_mean_cache <- new.env(parent = emptyenv())

operational_sens_for_mw <- tibble::tribble(
  ~field,          ~low,  ~high,
  "annual_volume",  500,   1500,
  "life_years",     5,     15,
  "discount",       0.00,  0.05,
  "fu_cost",        100,   1800,
  "device_cost",    25896, 50373
)

fu_grid_for_mw <- function(scn_name, baseline) {
  scn_name <- normalize_scenario(scn_name)
  if (scn_name == "Screening colonoscopy") c(low = 719, baseline = baseline, high = 952)
  else if (scn_name == "FIT-positive colonoscopy") c(low = 64, baseline = baseline, high = 151)
  else c(baseline = baseline)
}

build_oper_values_for_mw <- function(sc) {
  vals <- list()
  for (f in operational_sens_for_mw$field) {
    if (f == "discount") {
      vals[[f]] <- seq(0, 0.05, by = 0.01)
    } else {
      lo <- operational_sens_for_mw$low[operational_sens_for_mw$field == f][1]
      hi <- operational_sens_for_mw$high[operational_sens_for_mw$field == f][1]
      vals[[f]] <- c(low = lo, baseline = sc[[f]], high = hi)
    }
  }
  vals
}

compute_mw_mean_c5 <- function(scn_name, exclude_params) {
  scn_name <- normalize_scenario(scn_name)
  key <- paste0(scn_name, "||", paste(sort(exclude_params), collapse = ","))
  if (exists(key, envir = mw_mean_cache, inherits = FALSE)) {
    return(get(key, envir = mw_mean_cache, inherits = FALSE))
  }
  
  sc0 <- get_scenario_obj(scn_name)
  df_scn <- inputs %>% filter(Scenario == scn_name)
  base_pack <- apply_baselines(sc0, df_scn)
  sc_base <- base_pack$sc
  args_base <- apply_term_exclusions_to_args(base_pack$args, exclude_params)
  
  oper_values <- build_oper_values_for_mw(sc_base)
  fu_values <- fu_grid_for_mw(sc_base$name, sc_base$fu_per10k)
  
  grid <- tidyr::crossing(
    device_cost   = oper_values$device_cost,
    fu_cost       = oper_values$fu_cost,
    annual_volume = oper_values$annual_volume,
    life_years    = oper_values$life_years,
    discount      = oper_values$discount,
    fu_per10k     = fu_values
  )
  
  c5_vals <- purrr::pmap_dbl(
    grid,
    function(device_cost, fu_cost, annual_volume, life_years, discount, fu_per10k) {
      sc <- sc_base
      sc$device_cost <- device_cost
      sc$fu_cost <- fu_cost
      sc$annual_volume <- annual_volume
      sc$life_years <- as.integer(life_years)
      sc$discount <- discount
      sc$fu_per10k <- fu_per10k
      calc_c5(sc, args_base)
    }
  )
  
  val <- mean(c5_vals, na.rm = TRUE)
  assign(key, val, envir = mw_mean_cache)
  val
}

# -----------------------------
# Single tornado plot (baseline or MW mean)
# -----------------------------
make_centered_delta_tornado <- function(df_tbl, exclude_params,
                                        baseline_type = c("baseline_c5", "mw_mean"),
                                        title, filename) {
  baseline_type <- match.arg(baseline_type)
  
  if (baseline_type == "baseline_c5") {
    base_tbl <- df_tbl %>%
      distinct(Scenario, base = baseline_c5) %>%
      mutate(base_label = paste0("0 = Baseline (", fmt_dollars(base), ")"))
    
    x_lab <- "Change from baseline (USD per CRC prevented)\n(Negative = cheaper than baseline; positive = more expensive)"
  } else {
    base_tbl <- df_tbl %>%
      distinct(Scenario) %>%
      mutate(
        base = map_dbl(Scenario, ~ compute_mw_mean_c5(.x, exclude_params)),
        base_label = paste0("0 = MW mean (", fmt_dollars(base), ")")
      )
    
    x_lab <- "Change from MW mean (USD per CRC prevented)\n(Negative = cheaper than MW mean; positive = more expensive)"
  }
  
  df2 <- df_tbl %>%
    left_join(base_tbl, by = "Scenario") %>%
    mutate(
      Scenario = factor(Scenario, levels = scenario_order),
      delta_low  = low_abs  - base,
      delta_high = high_abs - base,
      impact = pmax(abs(delta_low), abs(delta_high), na.rm = TRUE)
    )
  
  df2 <- make_within_factor(df2, label_col = "Pretty", within_col = "Scenario", order_col = "impact")
  
  baseline_rows <- base_tbl %>%
    mutate(Scenario = factor(Scenario, levels = scenario_order)) %>%
    transmute(
      Method = NA_character_,
      Scenario = Scenario,
      Pretty = "BASELINE VALUE ($)",
      Parameter = NA_character_,
      baseline_c5 = base,
      min_c5 = NA_real_,
      max_c5 = NA_real_,
      low_abs = NA_real_,
      high_abs = NA_real_,
      base = base,
      base_label = base_label,
      delta_low = NA_real_,
      delta_high = NA_real_,
      impact = Inf
    )
  
  df2 <- bind_rows(df2, baseline_rows)
  df2 <- make_within_factor(df2, label_col = "Pretty", within_col = "Scenario", order_col = "impact")
  
  p <- ggplot(df2, aes(y = .key)) +
    geom_linerange(
      data = df2 %>% filter(Pretty != "BASELINE VALUE ($)"),
      aes(xmin = pmin(delta_low, delta_high), xmax = pmax(delta_low, delta_high)),
      linewidth = 1.1
    ) +
    facet_wrap(~ Scenario, ncol = 2, scales = "free_y", drop = FALSE) +
    geom_vline(xintercept = 0, linetype = "dashed", linewidth = 1.0) +
    geom_text(
      data = df2 %>% filter(Pretty == "BASELINE VALUE ($)"),
      aes(x = 0, y = .key, label = base_label),
      inherit.aes = FALSE,
      hjust = -0.05,
      vjust = 0.5,
      size = 3
    ) +
    coord_cartesian(clip = "off") +
    scale_y_discrete(labels = function(x) strip_within_suffix(x)) +
    scale_x_continuous(labels = scales::label_number(big.mark = ",", accuracy = 1)) +
    labs(
      title = title,
      x = x_lab,
      y = NULL
    ) +
    theme_bw() +
    theme(
      panel.grid.minor = element_blank(),
      plot.margin = margin(t = 12, r = 40, b = 12, l = 12, unit = "pt")
    )
  
  ggsave(file.path(output_dir, filename), p, width = 12.5, height = 6.0, dpi = 300)
  ggsave(file.path(output_dir, sub("\\.png$", ".pdf", filename)), p, width = 12.5, height = 6.0)
  p
}

# -----------------------------
# Combined baseline Endpoint native ggplot
# -----------------------------
make_combined_endpoint_baseline_ggplot <- function(exclusion_specs,
                                                   plot_order,
                                                   title = "Tornado (Δ vs baseline), Endpoint",
                                                   filename = "TORNADO_DELTA_BASELINE_ENDPOINT_COMBINED_NATIVE.png") {
  panel_levels <- unlist(lapply(plot_order, function(set_name) {
    spec <- exclusion_specs[[set_name]]
    paste0(spec$title, "\n", scenario_order)
  }))
  
  df_plot <- map_dfr(plot_order, function(set_name) {
    spec <- exclusion_specs[[set_name]]
    excl <- spec$exclude_params
    
    df_tbl <- run_owsa(method = "Endpoint", exclude_params = excl, n_grid = n_grid)
    
    base_tbl <- df_tbl %>%
      distinct(Scenario, base = baseline_c5) %>%
      mutate(
        Set_Name = set_name,
        Set_Title = spec$title,
        Scenario = factor(Scenario, levels = scenario_order),
        Panel = factor(
          paste0(Set_Title, "\n", as.character(Scenario)),
          levels = panel_levels
        ),
        base_label = paste0("0 = Baseline (", fmt_dollars(base), ")")
      )
    
    df2 <- df_tbl %>%
      mutate(
        Set_Name = set_name,
        Set_Title = spec$title,
        Scenario = factor(Scenario, levels = scenario_order)
      ) %>%
      left_join(
        base_tbl %>% select(Set_Name, Scenario, base, base_label, Panel),
        by = c("Set_Name", "Scenario")
      ) %>%
      mutate(
        delta_low  = low_abs  - base,
        delta_high = high_abs - base,
        impact = pmax(abs(delta_low), abs(delta_high), na.rm = TRUE)
      )
    
    baseline_rows <- base_tbl %>%
      transmute(
        Method = NA_character_,
        Scenario = Scenario,
        Pretty = "BASELINE VALUE ($)",
        Parameter = NA_character_,
        baseline_c5 = base,
        min_c5 = NA_real_,
        max_c5 = NA_real_,
        low_abs = NA_real_,
        high_abs = NA_real_,
        Set_Name = Set_Name,
        Set_Title = Set_Title,
        base = base,
        base_label = base_label,
        Panel = Panel,
        delta_low = NA_real_,
        delta_high = NA_real_,
        impact = Inf
      )
    
    bind_rows(df2, baseline_rows)
  })
  
  df_plot <- make_within_factor(
    df_plot,
    label_col = "Pretty",
    within_col = "Panel",
    order_col = "impact"
  )
  
  p <- ggplot(df_plot, aes(y = .key)) +
    geom_linerange(
      data = df_plot %>% filter(Pretty != "BASELINE VALUE ($)"),
      aes(xmin = pmin(delta_low, delta_high), xmax = pmax(delta_low, delta_high)),
      linewidth = 1.1
    ) +
    geom_vline(xintercept = 0, linetype = "dashed", linewidth = 1.0) +
    geom_text(
      data = df_plot %>% filter(Pretty == "BASELINE VALUE ($)"),
      aes(x = 0, y = .key, label = base_label),
      inherit.aes = FALSE,
      hjust = -0.05,
      vjust = 0.5,
      size = 2.8
    ) +
    facet_wrap(~ Panel, ncol = 2, scales = "free_y", drop = FALSE) +
    coord_cartesian(clip = "off") +
    scale_y_discrete(labels = function(x) strip_within_suffix(x)) +
    scale_x_continuous(labels = scales::label_number(big.mark = ",", accuracy = 1)) +
    labs(
      title = title,
      x = "Change from baseline (USD per CRC prevented)\n(Negative = cheaper than baseline; positive = more expensive)",
      y = NULL
    ) +
    theme_bw() +
    theme(
      panel.grid.minor = element_blank(),
      plot.margin = margin(t = 12, r = 40, b = 12, l = 12, unit = "pt"),
      strip.text = element_text(size = 9)
    )
  
  ggsave(file.path(output_dir, filename), p, width = 14, height = 18, dpi = 300)
  ggsave(file.path(output_dir, sub("\\.png$", ".pdf", filename)), p, width = 14, height = 18)
  
  p
}

