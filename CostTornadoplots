get_scenario_obj <- function(scn_name) {
  scn_name <- normalize_scenario(scn_name)
  idx <- which(vapply(scenarios, function(x) identical(normalize_scenario(x$name), scn_name), logical(1)))
  if (!length(idx)) stop("Scenario not found: ", scn_name)
  sc <- scenarios[[idx[1]]]
  sc$name <- normalize_scenario(sc$name)
  sc
}

# -----------------------------
# BASE ANALYSIS (discounted PV program costs)
# -----------------------------
analyse <- function(sc) {
  life_years <- suppressWarnings(as.integer(round(as.numeric(sc$life_years))))
  if (is.na(life_years) || life_years < 1L) stop("Invalid life_years")
  
  discount <- suppressWarnings(as.numeric(sc$discount))
  if (is.na(discount) || discount < 0) stop("Invalid discount")
  
  annual_volume <- suppressWarnings(as.numeric(sc$annual_volume))
  if (is.na(annual_volume) || annual_volume <= 0) stop("Invalid annual_volume")
  
  fu_per10k <- suppressWarnings(as.numeric(sc$fu_per10k))
  if (is.na(fu_per10k) || fu_per10k < 0) stop("Invalid fu_per10k")
  
  fu_cost <- suppressWarnings(as.numeric(sc$fu_cost))
  if (is.na(fu_cost) || fu_cost < 0) stop("Invalid fu_cost")
  
  device_cost <- suppressWarnings(as.numeric(sc$device_cost))
  if (is.na(device_cost) || device_cost < 0) stop("Invalid device_cost")
  
  inc_no <- suppressWarnings(as.numeric(sc$inc_no))
  inc_with <- suppressWarnings(as.numeric(sc$inc_with))
  if (is.na(inc_no) || is.na(inc_with)) stop("Invalid risks")
  
  yrs <- seq_len(life_years)
  tot_cols <- annual_volume * life_years
  annual_fu <- (fu_per10k / 1e4) * annual_volume
  
  pv_device   <- sum((device_cost / life_years) / (1 + discount)^yrs)
  pv_followup <- sum(annual_fu * fu_cost / (1 + discount)^yrs)
  
  arr_inc <- pmax(inc_no - inc_with, 0)
  crc_prevented <- arr_inc * tot_cols
  
  tibble(
    Scenario = sc$name,
    pv_device = pv_device,
    pv_followup = pv_followup,
    arr_incidence = arr_inc,
    crc_prevented = crc_prevented
  )
}

# -----------------------------
# EXPANDED ANALYSIS (CRC benefit deducted; emissions split corrected)
# -----------------------------
analyse_expanded <- function(sc,
                             cost_crc,
                             cost_polyp,
                             delta_ppc,
                             cost_co2,
                             colonoscopy_co2e,
                             cade_device_co2e) {
  base <- analyse(sc)
  
  discount <- as.numeric(sc$discount)
  life_years <- as.integer(round(as.numeric(sc$life_years)))
  df <- sum(1 / (1 + discount)^seq_len(life_years))
  
  V <- as.numeric(sc$annual_volume)
  annual_fu <- (as.numeric(sc$fu_per10k) / 1e4) * V
  
  pv_crc_savings <- as.numeric(cost_crc) * base$arr_incidence * V * df
  pv_polyp       <- as.numeric(cost_polyp) * as.numeric(delta_ppc) * V * df
  pv_co2 <- as.numeric(cost_co2) * ((V * as.numeric(cade_device_co2e)) + (annual_fu * as.numeric(colonoscopy_co2e))) * df
  
  pv_program <- base$pv_device + base$pv_followup
  pv_total <- pv_program - pv_crc_savings + pv_polyp + pv_co2
  
  tibble(Scenario = sc$name, c5 = safe_divide(pv_total, base$crc_prevented))
}

calc_c5 <- function(sc, args) {
  analyse_expanded(
    sc,
    cost_crc = args$cost_crc,
    cost_polyp = args$cost_polyp,
    delta_ppc = args$delta_ppc,
    cost_co2 = args$cost_co2,
    colonoscopy_co2e = args$colonoscopy_co2e,
    cade_device_co2e = args$cade_device_co2e
  )$c5
}

