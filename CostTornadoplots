# -----------------------------
# HELPERS
# -----------------------------
safe_divide <- function(num, den) ifelse(is.na(den) | den <= 0, NA_real_, num / den)

normalize_scenario <- function(x) {
  x %>% as.character() %>% str_squish() %>%
    str_replace_all("[\u2010\u2011\u2012\u2013\u2014\u2212]", "-")
}

coerce_for_model <- function(param, x) {
  x <- suppressWarnings(as.numeric(x))
  if (param == "life_years") return(pmax(1L, as.integer(round(x))))
  if (param == "annual_volume") return(pmax(1, round(x)))
  x
}

grid_values <- function(param, lo, hi, n = 11) {
  lo <- suppressWarnings(as.numeric(lo))
  hi <- suppressWarnings(as.numeric(hi))
  if (is.na(lo) || is.na(hi)) return(numeric(0))
  if (identical(lo, hi)) return(coerce_for_model(param, lo))
  if (param %in% c("life_years", "annual_volume")) {
    vals <- unique(as.integer(round(seq(lo, hi, length.out = n))))
    vals <- vals[vals >= 1]
    return(vals)
  }
  seq(lo, hi, length.out = n)
}

fmt_dollars <- function(x) scales::dollar(x, accuracy = 1)

# reorder-within helper (no extra packages)
make_within_factor <- function(df, label_col, within_col, order_col, sep = "___") {
  levs <- df %>%
    arrange(.data[[within_col]], desc(.data[[order_col]]), .data[[label_col]]) %>%
    mutate(.key = paste(.data[[label_col]], .data[[within_col]], sep = sep)) %>%
    pull(.key) %>%
    unique()
  
  df %>%
    mutate(
      .key = paste(.data[[label_col]], .data[[within_col]], sep = sep),
      .key = factor(.key, levels = rev(levs))
    )
}

strip_within_suffix <- function(x, sep = "___") sub(paste0(sep, ".*$"), "", x)

# Save 4 ggplots as a 2x2 combined figure using grid
save_plot_grid_2x2 <- function(plot_list, filename, title = NULL,
                               width = 20, height = 12, dpi = 300) {
  draw_page <- function() {
    grid::grid.newpage()
    
    if (is.null(title)) {
      lay <- grid::grid.layout(2, 2)
      grid::pushViewport(grid::viewport(layout = lay))
      pos <- list(c(1, 1), c(1, 2), c(2, 1), c(2, 2))
    } else {
      lay <- grid::grid.layout(
        nrow = 3, ncol = 2,
        heights = grid::unit.c(
          grid::unit(0.5, "in"),
          grid::unit(1, "null"),
          grid::unit(1, "null")
        )
      )
      grid::pushViewport(grid::viewport(layout = lay))
      grid::grid.text(
        title,
        vp = grid::viewport(layout.pos.row = 1, layout.pos.col = 1:2),
        gp = grid::gpar(fontface = "bold", cex = 1.15)
      )
      pos <- list(c(2, 1), c(2, 2), c(3, 1), c(3, 2))
    }
    
    for (i in seq_along(plot_list)) {
      print(
        plot_list[[i]],
        vp = grid::viewport(
          layout.pos.row = pos[[i]][1],
          layout.pos.col = pos[[i]][2]
        )
      )
    }
    
    grid::popViewport()
  }
  
  png(file.path(output_dir, filename), width = width, height = height, units = "in", res = dpi)
  draw_page()
  dev.off()
  
  pdf(file.path(output_dir, sub("\\.png$", ".pdf", filename)), width = width, height = height)
  draw_page()
  dev.off()
}

